# ─── BACKEND ENVIRONMENT VARIABLES ──────────────────────────────────────────
# Copy this file to .env and fill in your values

# Server
PORT=5001
NODE_ENV=development

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Firebase Admin SDK
# Option 1 (production/Vercel): paste the entire serviceAccount.json content as a single line
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"..."}

# Option 2 (local): leave empty and put serviceAccount.json in backend/config/serviceAccount.json
# FIREBASE_SERVICE_ACCOUNT=

# Firebase config
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
